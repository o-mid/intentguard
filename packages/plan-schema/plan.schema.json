{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentguard.local/schemas/plan-v1.json",
  "title": "IntentGuardPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "summary", "steps"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/approveStep" },
          { "$ref": "#/$defs/swapStep" },
          { "$ref": "#/$defs/transferStep" }
        ]
      }
    }
  },
  "$defs": {
    "decimalAmount": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]+)?$"
    },
    "tokenSymbol": {
      "type": "string",
      "enum": ["MOCK_USDC", "MOCK_ETH"]
    },
    "approveStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "token", "spender", "amount"],
      "properties": {
        "action": { "const": "approve" },
        "token": { "$ref": "#/$defs/tokenSymbol" },
        "spender": { "type": "string", "minLength": 1 },
        "amount": { "$ref": "#/$defs/decimalAmount" }
      }
    },
    "swapStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "tokenIn", "tokenOut", "amountIn", "minAmountOut", "maxSlippageBps"],
      "properties": {
        "action": { "const": "swap" },
        "tokenIn": { "$ref": "#/$defs/tokenSymbol" },
        "tokenOut": { "$ref": "#/$defs/tokenSymbol" },
        "amountIn": { "$ref": "#/$defs/decimalAmount" },
        "minAmountOut": { "$ref": "#/$defs/decimalAmount" },
        "maxSlippageBps": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "transferStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "token", "to", "amount"],
      "properties": {
        "action": { "const": "transfer" },
        "token": { "$ref": "#/$defs/tokenSymbol" },
        "to": { "type": "string", "minLength": 1 },
        "amount": { "$ref": "#/$defs/decimalAmount" }
      }
    }
  }
}
